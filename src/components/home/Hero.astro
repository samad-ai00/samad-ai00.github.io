<main class="relative min-h-[80vh] flex flex-col items-center justify-center text-center px-6 overflow-hidden">
  <div class="absolute inset-0 -z-10 flex items-center justify-center opacity-30 dark:opacity-20 pointer-events-none">
    <div class="w-[500px] h-[500px] bg-gradient-to-tr from-orange-400 to-amber-200 rounded-full blur-[120px]"></div>
  </div>

  <div class="max-w-4xl mx-auto space-y-6">
    <span class="inline-flex items-center gap-2 px-4 py-1.5 rounded-full text-xs font-semibold uppercase tracking-wider text-orange-600 dark:text-orange-400 bg-orange-50 dark:bg-orange-950/40 border border-orange-100 dark:border-orange-900/50">
      <span class="w-2 h-2 rounded-full bg-orange-500 animate-pulse"></span>
      Available for Work
    </span>

    <h1 class="text-5xl md:text-7xl font-extrabold tracking-tight text-neutral-900 dark:text-white">
      Hi, I'm <span class="text-transparent bg-clip-text bg-gradient-to-r from-orange-500 to-amber-500 dark:from-orange-400 dark:to-orange-500">Samad Satti</span>
    </h1>

    <p class="text-lg md:text-xl text-neutral-600 dark:text-neutral-400 font-medium max-w-2xl mx-auto leading-relaxed">
      <strong class="text-neutral-900 dark:text-white font-semibold">AI & ML Engineer.</strong> I build intelligent systems, deep learning architectures, and computer vision pipelines to extract real-world value from data.
    </p>

    <div class="pt-4 flex flex-col sm:flex-row items-center justify-center gap-4">
      <a href="#projects" class="w-full sm:w-auto px-6 py-3 bg-neutral-900 hover:bg-neutral-800 dark:bg-white dark:hover:bg-neutral-100 text-white dark:text-neutral-900 font-medium rounded-full inline-flex items-center justify-center gap-2 transition group shadow-lg shadow-neutral-900/10 dark:shadow-none">
        View my work
        <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="transform group-hover:translate-y-0.5 transition"><path d="m6 9 6 6 6-6"/></svg>
      </a>
      <a href="#contact" class="w-full sm:w-auto px-6 py-3 border border-neutral-200 dark:border-neutral-800 hover:bg-neutral-50 dark:hover:bg-neutral-900 text-neutral-700 dark:text-neutral-300 font-medium rounded-full inline-flex items-center justify-center transition">
        Get in touch
      </a>
    </div>
  </div>
</main>